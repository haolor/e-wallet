# Copy to backend/.env and frontend/.env

# Backend
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/hki-wallet?retryWrites=false
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=843567893696976453275974432697R634976R738467TR678T34865R6834R8763T478378637664538745673865783678548735687R3
JWT_REFRESH_SECRET=843567893696976453275974432697R634976R738467TR678T34865R6834R8763T478378637664538745673865783678548735687R3
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=change-me-cookie-secret
WEBHOOK_SECRET=change-me-webhook-secret
QR_HMAC_SECRET=change-me-qr-hmac-secret

# SMTP (OTP email) — bắt buộc để gửi OTP thật; nếu thiếu, dev mode trả mã OTP trong API
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="HKi Wallet <your_email@gmail.com>"

# Frontend (Vite)
VITE_API_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000
